# IMAP: 用于抓取邮件
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SSL=true
IMAP_USER=your_mail@example.com
IMAP_PASSWORD=your_mail_auth_code_or_password
IMAP_MAILBOX=INBOX

# SMTP: 用于发送简报
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=your_mail@example.com
SMTP_PASSWORD=your_mail_auth_code_or_password
MAIL_FROM=your_mail@example.com
DIGEST_TO=person1@example.com,person2@example.com
DIGEST_CC=

# AI: OpenAI-compatible Chat Completions
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxxxxxxx
LLM_MODEL=deepseek-chat

# 简报配置
DEMO_MODE=false
COMPANY_NAME=你的公司
DIGEST_LANGUAGE=zh-CN
DIGEST_LOOKBACK_HOURS=14
DIGEST_MAX_EMAILS=50
DIGEST_SEND_EMPTY=false
DIGEST_MARK_SEEN=false
TIMEZONE=Asia/Shanghai

# 状态文件：用于避免重复汇总
DIGEST_STATE_FILE=./state/mail_digest_state.json
DIGEST_PREVIEW_DIR=./preview
